# =============================================================================
# Docker Compose — Environment Variables
# =============================================================================
# Used when running the full stack locally via:
#   docker compose -f docker-compose.yml up
#
# Copy this file to .env in this directory and fill in the required values.
# Never commit .env to version control.
#
# The database and Redis credentials below are only for local Docker use.
# In production, Render injects all service credentials automatically.
#
# See platform/docs/environment/README.md for the full setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# Blocks AI Platform
# INTERNAL_ — backend-to-backend credentials; required by backend-api
# Get the API key from the Blocks dashboard.
# -----------------------------------------------------------------------------
BLOCKS_API_URL=https://api.blocks.team
BLOCKS_API_KEY=

# -----------------------------------------------------------------------------
# GitHub App Integration
# INTERNAL_ — App ID and private key used to authenticate as the GitHub App
# WEBHOOK_   — secret used to validate incoming GitHub webhook payloads
#
# How to obtain:
#   App ID:          GitHub → Settings → Developer settings → GitHub Apps → your app
#   Private key:     Download the .pem, then flatten to a single line:
#                    awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private-key.pem
#   Webhook secret:  Set a random value in GitHub App settings → Webhook secret
# -----------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Backend API
# SERVER_ — server-side only; required by backend-api when running in Docker
# CLERK_JWKS_URI: Clerk dashboard → your app → API Keys → JWKS URL
# -----------------------------------------------------------------------------
CLERK_JWKS_URI=

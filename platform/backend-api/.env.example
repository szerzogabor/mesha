# =============================================================================
# mesha-backend-api — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# Never commit .env to version control.
#
# Secret classification:
#   INTERNAL_  — credentials that never leave the backend (DB, Redis, auth keys)
#   WEBHOOK_   — secrets used to validate incoming webhook payloads
#   SERVER_    — server-side keys that must stay off the client
#
# For production deployment these are managed via Render environment variables.
# See platform/docs/environment/README.md for the full setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Render injects DB_HOST/PORT/NAME/USER/PASSWORD automatically from mesha-db.
# For local development use the values that match docker-compose.dev.yml.
# INTERNAL_ — never expose to the frontend or logs
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mesha
DB_USER=mesha
DB_PASSWORD=mesha

# -----------------------------------------------------------------------------
# Cache (Redis)
# Render injects REDIS_URL automatically from mesha-redis.
# INTERNAL_ — never expose to the frontend or logs
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication (Clerk)
# JWKS URI is used by Spring Security to validate JWT tokens issued by Clerk.
# Get from: https://dashboard.clerk.com → your app → API Keys
# SERVER_ — server-side only, never expose to the frontend
# -----------------------------------------------------------------------------
CLERK_JWKS_URI=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability — environment label and version are reported via OTel to Grafana Cloud
# -----------------------------------------------------------------------------
# Environment label (local | preview | staging | production)
APP_ENV=local

# Application version / release tag
APP_VERSION=0.0.1-SNAPSHOT

# -----------------------------------------------------------------------------
# GitHub App Integration
# Create a GitHub App at https://github.com/settings/apps
# INTERNAL_ — never expose to the frontend
# -----------------------------------------------------------------------------
# The numeric App ID shown on the GitHub App settings page
GITHUB_APP_ID=

# OAuth credentials for the installation redirect flow
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# RSA private key (.pem contents, newlines replaced with \n)
GITHUB_APP_PRIVATE_KEY=

# Secret used to validate incoming webhook payloads (X-Hub-Signature-256)
GITHUB_APP_WEBHOOK_SECRET=

# The slug name of your GitHub App
GITHUB_APP_NAME=mesha-github-app

# -----------------------------------------------------------------------------
# Blocks Integration
# WEBHOOK_  — secret used to validate incoming Blocks webhook payloads (X-Blocks-Signature)
# INTERNAL_ — API key and encryption secret never leave the backend
# -----------------------------------------------------------------------------
BLOCKS_WEBHOOK_SECRET=

# Base URL of the Blocks AI REST API (https://api.blocks.team in production)
BLOCKS_API_URL=https://api.blocks.team

# Default Blocks API key used as the bearer token for session creation
# Per-workspace keys (stored encrypted in workspace_blocks_config) take precedence
BLOCKS_API_KEY=

# AES encryption secret for per-workspace Blocks API keys stored in the database
# Must match the value set when keys were originally saved via BlocksConfigService
BLOCKS_ENCRYPTION_SECRET=

# -----------------------------------------------------------------------------
# Native client releases (Android APK distribution)
# INTERNAL_ — never expose to the frontend
# -----------------------------------------------------------------------------
# Comma-separated emails allowed to manage releases via a Clerk-authenticated session
# (list/publish/delete). Empty = nobody can.
PLATFORM_ADMIN_EMAILS=

# Long-lived token CI uses to publish APK builds via POST /api/releases (a Clerk
# admin session JWT is too short-lived for a build pipeline). Generate with
# `openssl rand -hex 32` and prefix with relpub_. Empty = CI publishing disabled.
APP_RELEASES_UPLOAD_TOKEN=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080

# =============================================================================
# mesha-backend-api — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# Never commit .env to version control.
#
# Secret classification:
#   INTERNAL_  — credentials that never leave the backend (DB, Redis, auth keys)
#   WEBHOOK_   — secrets used to validate incoming webhook payloads
#   SERVER_    — server-side keys that must stay off the client
#
# For production deployment these are managed via Render environment variables.
# See platform/docs/environment/README.md for the full setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Render injects DB_HOST/PORT/NAME/USER/PASSWORD automatically from mesha-db.
# For local development use the values that match docker-compose.dev.yml.
# INTERNAL_ — never expose to the frontend or logs
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mesha
DB_USER=mesha
DB_PASSWORD=mesha

# -----------------------------------------------------------------------------
# Cache (Redis)
# Render injects REDIS_URL automatically from mesha-redis.
# INTERNAL_ — never expose to the frontend or logs
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication (Clerk)
# JWKS URI is used by Spring Security to validate JWT tokens issued by Clerk.
# Get from: https://dashboard.clerk.com → your app → API Keys
# SERVER_ — server-side only, never expose to the frontend
# -----------------------------------------------------------------------------
CLERK_JWKS_URI=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability (Sentry)
# SERVER_ — backend DSN; different project from the frontend DSN
# -----------------------------------------------------------------------------
SENTRY_DSN=

# Environment label sent to Sentry (local | preview | staging | production)
APP_ENV=local

# Application version / release tag
APP_VERSION=0.0.1-SNAPSHOT

# -----------------------------------------------------------------------------
# GitHub App Integration
# Create a GitHub App at https://github.com/settings/apps
# INTERNAL_ — never expose to the frontend
# -----------------------------------------------------------------------------
# The numeric App ID shown on the GitHub App settings page
GITHUB_APP_ID=

# OAuth credentials for the installation redirect flow
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# RSA private key (.pem contents, newlines replaced with \n)
GITHUB_APP_PRIVATE_KEY=

# Secret used to validate incoming webhook payloads (X-Hub-Signature-256)
GITHUB_APP_WEBHOOK_SECRET=

# The slug name of your GitHub App
GITHUB_APP_NAME=mesha-github-app

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080

# -----------------------------------------------------------------------------
# Distributed Tracing — OpenTelemetry Java Agent → Grafana Cloud Tempo
#
# The OTel Java agent (loaded via -javaagent in Dockerfile) auto-instruments
# Spring Boot, JDBC, Redis, and HTTP clients and exports spans to any OTLP
# backend. For Grafana Cloud Tempo:
#
#   OTEL_EXPORTER_OTLP_ENDPOINT   OTLP push endpoint (same as frontend)
#                                  e.g. https://otlp-gateway-prod-eu-central-0.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_HEADERS    Basic auth header (base64 of "<instance_id>:<api_key>")
#                                  e.g. Authorization=Basic <base64>
#   OTEL_EXPORTER_OTLP_PROTOCOL   http/protobuf  (Grafana Cloud gateway is HTTP, not gRPC)
#   OTEL_SERVICE_NAME             Identifies the service in Tempo / Grafana dashboards
#   OTEL_RESOURCE_ATTRIBUTES      Extra resource labels attached to every span
#   OTEL_TRACES_SAMPLER           Sampler type (parentbased_traceidratio recommended)
#   OTEL_TRACES_SAMPLER_ARG       Sampling ratio (1.0 = 100%, 0.1 = 10%)
#   OTEL_TRACES_EXPORTER          otlp           (traces → Tempo via /v1/traces)
#   OTEL_LOGS_EXPORTER            otlp           (logs   → Loki  via /v1/logs)
#   OTEL_METRICS_EXPORTER         none           (metrics handled by Actuator)
#   OTEL_PROPAGATORS              tracecontext,baggage
#
# For local development leave these unset — the agent emits spans to stdout only.
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAME=mesha-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,service.version=0.0.1-SNAPSHOT
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# -----------------------------------------------------------------------------
# Log Shipping — Loki4j → Grafana Cloud Loki (optional, local dev only)
#
# In production, logs are shipped via OTEL_LOGS_EXPORTER=otlp above.
# Set LOKI_URL locally to also enable the Loki4j Logback appender for direct
# Loki push alongside OTLP export (useful for testing Loki queries locally).
#
# For Grafana Cloud Loki:
#   LOKI_URL       Push endpoint  e.g. https://logs-prod-XX.grafana.net
#   LOKI_USERNAME  Loki instance ID (numeric, from Grafana Cloud portal)
#   LOKI_PASSWORD  Grafana Cloud API key with MetricsPublisher role
#
# For local development leave these unset — logs are written to console only.
# -----------------------------------------------------------------------------
LOKI_URL=
LOKI_USERNAME=
LOKI_PASSWORD=

<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- JSON console appender — all MDC fields (correlationId, traceId, userId, etc.) are included automatically -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>workspaceId</includeMdcKeyName>
            <includeMdcKeyName>requestMethod</includeMdcKeyName>
            <includeMdcKeyName>requestUri</includeMdcKeyName>
            <includeMdcKeyName>userAgent</includeMdcKeyName>
            <!-- GitHub integration fields -->
            <includeMdcKeyName>githubEventId</includeMdcKeyName>
            <includeMdcKeyName>githubEventType</includeMdcKeyName>
            <includeMdcKeyName>githubInstallationId</includeMdcKeyName>
            <includeMdcKeyName>repoFullName</includeMdcKeyName>
            <includeMdcKeyName>prNumber</includeMdcKeyName>
            <includeMdcKeyName>repositoryId</includeMdcKeyName>
            <!-- AI / Blocks session fields -->
            <includeMdcKeyName>sessionId</includeMdcKeyName>
            <includeMdcKeyName>draftId</includeMdcKeyName>
            <includeMdcKeyName>issueId</includeMdcKeyName>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
            <!-- Include short caller info for debug builds; omit in production if performance matters -->
            <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
        </encoder>
    </appender>

    <!-- Sentry appender — forwards WARN+ log events as Sentry issues (captures 4xx/5xx), DEBUG+ as breadcrumbs -->
    <appender name="SENTRY" class="io.sentry.logback.SentryAppender">
        <minimumEventLevel>WARN</minimumEventLevel>
        <minimumBreadcrumbLevel>DEBUG</minimumBreadcrumbLevel>
    </appender>

    <springProfile name="local">
        <!-- Human-readable console for local development alongside JSON -->
        <appender name="READABLE_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId}] - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="DEBUG">
            <appender-ref ref="READABLE_CONSOLE"/>
            <appender-ref ref="SENTRY"/>
        </root>
        <logger name="com.mesha" level="DEBUG"/>
        <logger name="org.springframework.security" level="INFO"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
    </springProfile>

    <springProfile name="!local">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="SENTRY"/>
        </root>
        <logger name="com.mesha" level="DEBUG"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>
</configuration>

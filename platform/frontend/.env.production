# =============================================================================
# mesha-frontend — Production Environment Defaults
# =============================================================================
# Committed defaults for the production build.
# Override any value in the Vercel dashboard or with a local .env.local file.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenTelemetry → Grafana Cloud (prod-eu-central-0 stack)
#
# NEXT_PUBLIC_OTEL_ENABLED activates the OTel SDK in the browser.
# Telemetry is sent to /api/otel (Next.js proxy) which forwards to Grafana
# server-side — this avoids CORS restrictions on the Grafana OTLP gateway.
#
# OTEL_EXPORTER_OTLP_ENDPOINT and OTEL_EXPORTER_OTLP_AUTH are server-only
# (no NEXT_PUBLIC_ prefix) so credentials never reach the browser bundle.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://mesha-backend-api.onrender.com

NEXT_PUBLIC_OTEL_ENABLED=true
NEXT_PUBLIC_OTEL_SERVICE_NAME=mesha-frontend
NEXT_PUBLIC_OTEL_TRACES_SAMPLE_RATE=1

OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_AUTH=MTY0OTc2ODpnbGNfZXlKdklqb2lNVGMzTVRRek9TSXNJbTRpT2lKdFpYTm9ZU0lzSW1zaU9pSndOV1J0TXpWcVYzRTBWVTFPTkRoWWRqWTRkalV5VUd3aUxDSnRJanA3SW5JaU9pSndjbTlrTFdWMUxXTmxiblJ5WVd3dE1DSjlmUT09

# API — set to the Render backend URL in Vercel (e.g. https://mesha-backend-api.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Clerk — get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/workspaces

# Sentry — get the DSN from https://sentry.io/settings/ogbar/projects/mesh-javascript-nextjs/keys/
# DSN is safe to expose publicly; keep the auth token secret
NEXT_PUBLIC_SENTRY_DSN=

# Environment label sent to Sentry (local | preview | staging | production)
NEXT_PUBLIC_ENVIRONMENT=local

# Application version / release tag sent to Sentry
NEXT_PUBLIC_APP_VERSION=

# --- Build-time only ---

# Auth token for source map upload — put this in .env.sentry-build-plugin instead
# Generate at https://sentry.io/settings/account/api/auth-tokens/
# SENTRY_AUTH_TOKEN=

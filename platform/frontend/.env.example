# =============================================================================
# mesha-frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for local development.
# Never commit .env.local to version control.
#
# Secret classification:
#   PUBLIC_   — safe to expose to the browser (NEXT_PUBLIC_* prefix in Next.js)
#   SERVER_   — server-side only; never sent to the browser
#
# For Vercel deployment set these in the Vercel dashboard under
# Project → Settings → Environment Variables.
# See platform/docs/environment/README.md for the full setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# PUBLIC_ — the frontend reads this at runtime to build API request URLs
# Set to the Render backend URL in Vercel (e.g. https://mesha-backend-api.onrender.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# GitHub App
# PUBLIC_ — app slug used to build the GitHub App installation URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GITHUB_APP_NAME=mesha-github-app

# -----------------------------------------------------------------------------
# Authentication (Clerk)
# PUBLIC_  — publishable key is safe to expose to the browser
# SERVER_  — secret key must never leave the server
# Get both from: https://dashboard.clerk.com → your app → API Keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/workspaces

# -----------------------------------------------------------------------------
# Observability (Sentry)
# PUBLIC_ — DSN is safe to expose publicly (it only allows data ingestion)
# SERVER_ — auth token must never be committed; use .env.sentry-build-plugin
# Get the DSN from: https://sentry.io/settings/ → your project → Client Keys
# Generate the auth token at: https://sentry.io/settings/account/api/auth-tokens/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=

# Environment label sent to Sentry and OTel (local | preview | staging | production)
NEXT_PUBLIC_ENVIRONMENT=local

# Application version / release tag sent to Sentry and OTel
NEXT_PUBLIC_APP_VERSION=

# --- Build-time only ---

# SERVER_ — auth token for source map upload; put in .env.sentry-build-plugin instead
# SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry → Grafana Cloud via server-side proxy)
#
# The browser SDK sends telemetry to /api/otel (Next.js API route) which
# forwards to Grafana Cloud server-side — no CORS restrictions apply.
#
# PUBLIC_ — enables the OTel SDK in the browser (set to "true" to activate)
# SERVER_ — Grafana credentials stay server-side; never reach the browser bundle
#
# Grafana Cloud OTLP gateway URL — find it in:
#   Grafana Cloud → your stack → OpenTelemetry → OTLP endpoint
#   Format: https://otlp-gateway-<region>.grafana.net/otlp
#
# OTLP basic-auth — base64("<instanceId>:<apiToken>") where apiToken has
#   MetricsPublisher + LogsPublisher + TracesPublisher scopes.
#   Generate in: Grafana Cloud → your stack → Access Policies → Add token
#   Then encode:  echo -n "<instanceId>:<token>" | base64
# -----------------------------------------------------------------------------

# PUBLIC_ — set to "true" to enable OTel tracing/logging in the browser
NEXT_PUBLIC_OTEL_ENABLED=

# Service name reported in traces and logs (default: mesha-frontend)
NEXT_PUBLIC_OTEL_SERVICE_NAME=mesha-frontend

# Fraction of traces to sample — 1 = 100%, 0.1 = 10% (default: 1)
NEXT_PUBLIC_OTEL_TRACES_SAMPLE_RATE=1

# SERVER_ — Grafana Cloud OTLP gateway endpoint (server-only, no NEXT_PUBLIC_ prefix)
OTEL_EXPORTER_OTLP_ENDPOINT=

# SERVER_ — base64("<instanceId>:<apiToken>") for Grafana Cloud basic-auth (server-only)
OTEL_EXPORTER_OTLP_AUTH=

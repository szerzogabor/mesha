# API
NEXT_PUBLIC_API_URL=http://localhost:8080

# Sentry — get these from https://sentry.io/settings/<org>/projects/<project>/keys/
# DSN is safe to expose publicly; keep the auth token secret
NEXT_PUBLIC_SENTRY_DSN=

# Environment label sent to Sentry (local | preview | staging | production)
NEXT_PUBLIC_ENVIRONMENT=local

# Application version / release tag sent to Sentry
NEXT_PUBLIC_APP_VERSION=

# --- Server-side / build-time only (do NOT prefix with NEXT_PUBLIC_) ---

# Auth token for source map upload (requires project:write scope)
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# Sentry organisation slug (shown in Settings → General)
SENTRY_ORG=

# Sentry project slug (shown in Settings → Projects)
SENTRY_PROJECT=

# Server-side DSN override (falls back to NEXT_PUBLIC_SENTRY_DSN when unset)
SENTRY_DSN=

# Environment override for server/edge runtimes (falls back to NEXT_PUBLIC_ENVIRONMENT)
ENVIRONMENT=

# Release override for server/edge runtimes (falls back to NEXT_PUBLIC_APP_VERSION)
APP_VERSION=
